# Make.com
MAKE_API_KEY=your_make_api_key_here

# Google Sheets
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Slack
SLACK_WEBHOOK_ECOMMERCE_ALERTS=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# WooCommerce (for production - swap in real credentials)
WOOCOMMERCE_URL=https://yourstore.com
WOOCOMMERCE_CONSUMER_KEY=your_key_here
WOOCOMMERCE_CONSUMER_SECRET=your_secret_here

# Meta Ads (for production - swap in real credentials)
META_ADS_ACCESS_TOKEN=your_token_here
META_AD_ACCOUNT_ID=your_account_id_here